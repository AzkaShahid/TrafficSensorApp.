<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    tools:context=".ui.sidenavigation.home.HomeFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/margin_50"
        android:background="@color/light_green"
        android:gravity="center"
        >
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/margin_10"
            android:textSize="@dimen/font_24"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:text="EUL Helper"
            android:fontFamily="@font/catilde_semibold"

            />

    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        app:tabBackground="@drawable/tab_color_selector_1"
        android:background="@drawable/ic_rectangle_white"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabIndicator="@null"
        android:elevation="@dimen/margin_8"
        android:backgroundTint="@color/white"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="@color/black"
        android:layout_marginTop="@dimen/margin_20"
        android:layout_marginHorizontal="@dimen/margin_20"
        />



    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        />

<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"/>
    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_scan"/>

</LinearLayout>

